.page{display:grid;gap:20px;max-width:1050px;margin:auto;padding:28px}header>a{display:flex;gap:6px;color:#2563eb;text-decoration:none;font-weight:800}header>span{display:block;margin-top:18px;color:#2563eb;font-size:.76rem;font-weight:900;text-transform:uppercase}h1{margin:5px 0;font-size:2.4rem}nav{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}nav div{display:flex;align-items:center;gap:8px;padding:12px;border-radius:11px;background:#f1f5f9;color:#64748b;font-size:.78rem;font-weight:800}nav b{display:grid;width:25px;height:25px;place-items:center;border-radius:50%;background:#dbe4ee}.active{background:#eaf2ff!important;color:#1d4ed8!important}.active b{background:#2563eb;color:white}form{display:grid;gap:16px}section{padding:25px;border:1px solid #dce5ee;border-radius:18px;background:white}.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}label{display:grid;gap:7px;color:#475569;font-size:.85rem;font-weight:700}input,select,textarea{padding:12px;border:1px solid #cbd5e1;border-radius:10px;font:inherit}footer{display:flex;justify-content:space-between}button{display:flex;align-items:center;gap:8px;padding:12px 18px;border:1px solid #cbd5e1;border-radius:11px;background:white;font-weight:800}.primary{border:0;background:#2563eb;color:white}.review{padding:20px;border-radius:14px;background:#f8fbff}.error{padding:13px;background:#fef2f2;color:#b91c1c}@media(max-width:760px){.page{padding:16px 14px 96px}nav{grid-template-columns:1fr 1fr}.grid{grid-template-columns:1fr}}
